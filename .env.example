# Server
PORT=8080
BASE_URL=http://localhost:8080
BIND_ADDR=127.0.0.1

# Optional API protection for /github/stats and /jira/stats
# When set, send this value in X-Internal-API-Key or Authorization: Bearer <key>
INTERNAL_TRACKER_API_KEY=

# GitHub
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Jira
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Database (if used later)
DATABASE_URL=
